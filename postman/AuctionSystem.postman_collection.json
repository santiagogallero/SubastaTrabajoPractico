    {
      "name": "2. Login",
      "item": [
        {
          "name": "Auth - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const raw = pm.response.text();",
                  "let json = null;",
                  "if (raw && raw.trim().length > 0) {",
                  "  try {",
                  "    json = JSON.parse(raw);",
                  "  } catch (e) {",
                  "    console.log('Respuesta no JSON:', raw);",
                  "  }",
                  "}",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "} else {",
                  "  pm.collectionVariables.unset('token');",
                  "  if (json && json.message) {",
                  "    console.log('Login error:', json.message);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@auction.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
